{
  "name": "codexdash",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @codexdash/api --filter @codexdash/web dev",
    "dev:api": "pnpm --filter @codexdash/api start:dev",
